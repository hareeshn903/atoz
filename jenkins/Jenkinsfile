pipeline {

    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK21'
    }

    environment {

        APP_NAME = "mini-account-management"

        IMAGE_NAME = "YOUR_DOCKERHUB_USERNAME/mini-account-management"

        IMAGE_TAG = "${BUILD_NUMBER}"

        DOCKER_CREDENTIALS_ID = "dockerhub-creds"

        SONARQUBE_ENV = "sonarqube"

        KUBECONFIG = credentials('kubeconfig')

    }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Unit Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('SonarQube Analysis') {
            steps {

                withSonarQubeEnv("${SONARQUBE_ENV}") {

                    sh """
                    mvn sonar:sonar \
                    -Dsonar.projectKey=${APP_NAME} \
                    -Dsonar.projectName=${APP_NAME}
                    """
                }
            }
        }

        stage('Docker Build') {
            steps {

                sh """
                docker build \
                -t ${IMAGE_NAME}:${IMAGE_TAG} \
                -t ${IMAGE_NAME}:latest .
                """
            }
        }

        stage('Trivy Scan') {
            steps {

                sh """
                trivy image \
                --exit-code 0 \
                --severity HIGH,CRITICAL \
                ${IMAGE_NAME}:${IMAGE_TAG}
                """
            }
        }

        stage('Docker Push') {
            steps {

                withDockerRegistry(
                    credentialsId: "${DOCKER_CREDENTIALS_ID}",
                    url: ""
                ) {

                    sh """
                    docker push ${IMAGE_NAME}:${IMAGE_TAG}
                    docker push ${IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('Helm Lint') {
            steps {

                sh """
                helm lint helm/mini-account-management
                """
            }
        }

        stage('Helm Template Validation') {
            steps {

                sh """
                helm template mini-account-management \
                helm/mini-account-management > rendered.yaml
                """
            }
        }

        stage('Deploy To Kubernetes') {
            steps {

                sh """
                helm upgrade --install mini-account-management \
                helm/mini-account-management \
                --namespace siri \
                --create-namespace \
                --set image.repository=${IMAGE_NAME} \
                --set image.tag=${IMAGE_TAG}
                """
            }
        }

        stage('Verify Deployment') {
            steps {

                sh """
                kubectl rollout status deployment/mini-account-management \
                -n siri
                """

                sh """
                kubectl get pods -n siri
                """
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
        }
    }
}